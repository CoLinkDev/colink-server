# ===== Required =====
COLINK_JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# ===== Optional (defaults shown) =====
# COLINK_SERVER_PORT=8080
# COLINK_JWT_ACCESS_TTL=15m
# COLINK_JWT_REFRESH_TTL=720h
# COLINK_WS_TICKET_TTL=30s
# COLINK_UPDATE_CHECK_INTERVAL=30m
# COLINK_GITHUB_TOKEN=
# COLINK_GITHUB_REPOS=CoLinkDev:colink-android:android,CoLinkDev:colink-desktop:windows
# COLINK_HTTP_PROXY=http://host.docker.internal:7890
# COLINK_HTTPS_PROXY=http://host.docker.internal:7890
# COLINK_NO_PROXY=localhost,127.0.0.1,postgres

# ===== When running a binary directly =====
# DATABASE_USER=colink
# DATABASE_PASSWORD=colink
