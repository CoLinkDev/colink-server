# CoLink Configuration
# CoLink binaries read variables directly. Docker compose passes the
# same names into containers.


# ============================================================
# Required. HS256 signing secret used by the server.
COLINK_JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# ============================================================
# Host port exposed by nginx when using docker compose.
# COLINK_PUBLIC_PORT=37777

# ============================================================
# Gin mode: debug or release. Compose sets this per service.
# COLINK_SERVER_MODE=debug

# ============================================================
# HTTP listen port. Compose sets 8080 for server and 8081 for update.
# COLINK_SERVER_PORT=8080

# ============================================================
# Access token TTL.
# COLINK_JWT_ACCESS_TTL=72h

# ============================================================
# Refresh token TTL.
# COLINK_JWT_REFRESH_TTL=720h

# ============================================================
# WebSocket ticket TTL.
# COLINK_WS_TICKET_TTL=30s

# ============================================================
# PostgreSQL connection settings. Compose sets these for containers.
# COLINK_DATABASE_HOST=localhost
# COLINK_DATABASE_PORT=5432
# COLINK_DATABASE_USER=colink
# COLINK_DATABASE_PASSWORD=
# COLINK_DATABASE_DBNAME=colink
# COLINK_DATABASE_SSLMODE=disable

# ============================================================
# Maximum time to wait for PostgreSQL during startup.
# COLINK_DATABASE_CONNECT_TIMEOUT=2m

# ============================================================
# GitHub release check interval for the update service.
# COLINK_UPDATE_CHECK_INTERVAL=30m

# ============================================================
# Update asset storage path.
# COLINK_UPDATE_STORAGE_PATH=./data/updates

# ============================================================
# Optional GitHub token for release checks and asset downloads.
# COLINK_UPDATE_GITHUB_TOKEN=

# ============================================================
# Comma-separated release sources: owner:repo:platform.
# COLINK_UPDATE_GITHUB_REPOS=CoLinkDev:colink-android:android,CoLinkDev:colink-desktop:windows,CoLinkDev:colink-desktop:linux

# ============================================================
# Optional proxy settings for image builds and the update service.
# COLINK_HTTP_PROXY=http://host.docker.internal:7890
# COLINK_HTTPS_PROXY=http://host.docker.internal:7890
# COLINK_NO_PROXY=localhost,127.0.0.1,postgres,server,update
